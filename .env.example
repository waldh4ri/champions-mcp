# champions-mcp — docker-compose environment variables
# Copy this file to .env and fill in values before running `docker compose up`.

# ---- Published port for the MCP server (host-side) ----
MCP_PORT=8000

# ---- Calc image tag (pre-built; see README for build command) ----
CALC_IMAGE=champions-calc:latest

# ---- Limitless API key (optional; unlocks /decks endpoint) ----
LIMITLESS_API_KEY=

# ---- Prewarm on startup (1=yes, 0=skip if data volume already populated) ----
CHAMPIONS_MCP_PREWARM=1

# ---- Meta / cache TTLs (seconds) ----
CHAMPIONS_MCP_META_TTL=21600
CHAMPIONS_MCP_HTTP_TIMEOUT=20
